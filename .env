OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_TITLE=stuni-web
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-20b:free,google/gemma-3-4b-it:free,qwen/qwen3-4b:free

# Audio generation mode:
# - remote: uses server-side /api/tts route (recommended for low-memory/devcontainers)
# - local: uses browser-side Transformers.js TTS
NEXT_PUBLIC_AUDIO_PROVIDER=remote

# ── Server-side TTS ─────────────────────────────────────────────────────────
# Option A (default): free local inference via @xenova/transformers.
#   Model is downloaded once and cached in node_modules/.cache on first request.
#   Leave TTS_API_BASE_URL empty to use this path.
TTS_MODEL=Xenova/mms-tts-eng

# Option B: OpenAI-compatible remote TTS API (e.g. OpenRouter, OpenAI, etc.)
#   Set TTS_API_BASE_URL to switch to this path.
#   If TTS_API_KEY is empty, OPENROUTER_API_KEY is used as the bearer token.
# TTS_API_BASE_URL=https://openrouter.ai/api/v1
# TTS_API_KEY=
# TTS_MODEL=openrouter/auto
# TTS_VOICE=alloy

# ── Local browser TTS fallback ───────────────────────────────────────────────
# Used when NEXT_PUBLIC_AUDIO_PROVIDER=local or when remote TTS fails and
# NEXT_PUBLIC_ENABLE_LOCAL_TTS_FALLBACK=true.
NEXT_PUBLIC_ENABLE_LOCAL_TTS_FALLBACK=false
NEXT_PUBLIC_LOCAL_TTS_MODEL=Xenova/mms-tts-eng

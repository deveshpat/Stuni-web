OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_TITLE=stuni-web
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_FALLBACK_MODELS=openai/gpt-oss-20b:free,google/gemma-3-4b-it:free,qwen/qwen3-4b:free

# Audio generation mode:
# - remote: uses server-side OpenAI-compatible TTS API (recommended for low-memory/devcontainers)
# - local: uses browser-side Transformers.js TTS
NEXT_PUBLIC_AUDIO_PROVIDER=remote

# TTS runs server-side via @xenova/transformers — completely free, no API key needed.
# Model is downloaded once and cached in node_modules/.cache on first request.
# Alternatives: Xenova/speecht5_tts (requires HF_TOKEN, higher quality)
TTS_MODEL=Xenova/mms-tts-eng

# Local TTS fallback model (used when NEXT_PUBLIC_AUDIO_PROVIDER=local or remote audio fails)
NEXT_PUBLIC_ENABLE_LOCAL_TTS_FALLBACK=false
NEXT_PUBLIC_LOCAL_TTS_MODEL=Xenova/mms-tts-eng
